FLASK_ENV=development
# Set to 1 only on a trusted local machine. Never enable on a public/LAN host.
# When 0 (production), SECRET_KEY MUST be set or the app refuses to start.
FLASK_DEBUG=0
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Request hardening
MAX_CONTENT_LENGTH_MB=5
MAX_FRAME_PIXELS=2073600
MAX_FRAME_DIMENSION=4096
RATE_LIMIT_PREDICT=10 per second; 600 per minute
RATE_LIMIT_RESET=5 per second; 60 per minute
RATE_LIMIT_DEFAULT=120 per minute
MAX_SESSIONS=1000

MEDIAPIPE_MODEL_PATH=models/mediapipe/hand_landmarker.task
# Optional integrity pin. Run once to record the digest, then set it here.
# When set, mismatched files raise on startup.
MEDIAPIPE_MODEL_SHA256=

# Comma-separated list, or "*" to allow all origins (dev only).
CORS_ORIGINS=*

YOLO_WEIGHTS=models/yolov8/best.pt
YOLO_CONF_THRESHOLD=0.5

LSTM_MODEL_PATH=models/lstm/bisindo_lstm.h5
LSTM_LABELS_PATH=models/lstm/labels.json
LSTM_SEQUENCE_LENGTH=30
LSTM_CONF_THRESHOLD=0.7

LETTER_MODEL_PATH=models/letter_mlp/bisindo_letter.h5
LETTER_LABELS_PATH=models/letter_mlp/labels.json
LETTER_CONF_THRESHOLD=0.7

TTS_LANG=id
TTS_OUTPUT_DIR=app/static/audio
